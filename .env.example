# ---- S3 / LocalStack (zone RAW) --------------------------------------------
S3_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=eu-west-3
S3_BUCKET_RAW=raw

# ---- MySQL (zone STAGING) --------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=staging

# ---- MongoDB (zone CURATED) ------------------------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=curated
MONGO_COLLECTION=station_analytics

# ---- Sources de donnees ----------------------------------------------------
VELIB_STATUS_URL=https://velib-metropole-opendata.smovengo.cloud/opendata/Velib_Metropole/station_status.json
VELIB_INFORMATION_URL=https://velib-metropole-opendata.smovengo.cloud/opendata/Velib_Metropole/station_information.json
WEATHER_URL=https://api.open-meteo.com/v1/forecast
WEATHER_LAT=48.8566
WEATHER_LON=2.3522
# Timeout (secondes) et nombre de retries pour les appels HTTP sortants
HTTP_TIMEOUT=15
HTTP_MAX_RETRIES=3

# ---- Divers ----------------------------------------------------------------
PIPELINE_VERSION=1.0.0
LOG_LEVEL=INFO
